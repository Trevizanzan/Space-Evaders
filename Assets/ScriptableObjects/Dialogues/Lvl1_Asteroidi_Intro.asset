%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: b8969dd8d282e784eb7caed61050d48d, type: 3}
  m_Name: Lvl1_Asteroidi_Intro
  m_EditorClassIdentifier: Assembly-CSharp::DialogueSequence
  speakerKey: IA
  defaultCharsPerSecond: 35
  isOpening: 0
  lines:
  - italian: Sei sveglio, finalmente.
    english: 
    pauseAfter: 0.4
    charsPerSecond: 0
  - italian: Calma. Respira. Lascia che la nave si stabilizzi intorno a te.
    english: 
    pauseAfter: 0.4
    charsPerSecond: 0
  - italian: ...
    english: 
    pauseAfter: 0.4
    charsPerSecond: 0
  - italian: Mi senti?
    english: 
    pauseAfter: 0.4
    charsPerSecond: 0
  - italian: "Bene. Sono io. Sono qui con te. Sono sempre stata qui. Non ricordi
      tutto, vero? \xC8 normale. La memoria torna a strati. Torner\xE0."
    english: 
    pauseAfter: 0.4
    charsPerSecond: 0
  - italian: "Per adesso ti basta sapere una cosa: questa nave. \xC8 tua. Ti conosce.
      \xC8 stata costruita su di te \u2014 sulla tua mano, sui tuoi riflessi, sul
      tuo respiro."
    english: 
    pauseAfter: 0.4
    charsPerSecond: 0
  - italian: "I comandi rispondono al pensiero un istante prima del gesto. Le armi
      pesano quanto pesa la tua intenzione. Non sei tu dentro una macchina. Siete
      una cosa sola. Fidati di lei: ti porter\xE0 dove vuoi andare."
    english: 
    pauseAfter: 0.4
    charsPerSecond: 0
  - italian: ...
    english: 
    pauseAfter: 0.4
    charsPerSecond: 0
  - italian: Siamo nello spazio profondo. Lontani da tutto, lontani da tutti. Davanti
      a noi solo nero, e qualche luce tra il nero.
    english: 
    pauseAfter: 0.4
    charsPerSecond: 0
  - italian: Tu vuoi andare avanti. Lo senti, vero? Quel tirare dentro al petto,
      quel desiderio di non fermarti.
    english: 
    pauseAfter: 0.4
    charsPerSecond: 0
  - italian: "Non te lo spiego oggi. Te lo spiegherai da solo, strada facendo. Per
      ora seguilo: \xE8 giusto seguirlo."
    english: 
    pauseAfter: 0.4
    charsPerSecond: 0
  - italian: "Tra noi e ci\xF2 che cerchi c'\xE8 del rumore. Detriti. Cacciatori.
      Vecchi relitti che si sono dimenticati di essere stati navi."
    english: 
    pauseAfter: 0.4
    charsPerSecond: 0
  - italian: "Te ne occuperai uno alla volta. Io sar\xF2 qui. Ti dir\xF2 cosa vedo,
      ti dir\xF2 cosa fare. Non sei solo."
    english: 
    pauseAfter: 0.4
    charsPerSecond: 0
  - italian: "Ce n'\xE8 gi\xE0 qualcosa in arrivo. Niente di serio \u2014 un campo
      di detriti per scaldarti. Quando ti senti pronto, vai."
    english: 
    pauseAfter: 0.4
    charsPerSecond: 0
